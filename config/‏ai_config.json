{
  "vector_db": {
    "enabled": true,
    "provider": "chromadb",
    "collection_name": "security_knowledge",
    "persist_directory": "data/vector_store",
    "similarity_threshold": 0.25,
    "max_history_days": 90,
    "embedding_model": "all-MiniLM-L6-v2"
  },
  "self_reflection": {
    "enabled": true,
    "review_cycle_hours": 24,
    "min_confidence_for_suggestion": 0.90,
    "log_path": "logs/self_reflection.log"
  },
  "agent_core": {
    "enabled": false,
    "simulation_mode": true,
    "impact_analysis_depth": "medium"
  },
  "privacy": {
    "sanitize_targets_before_embedding": true,
    "exclude_sensitive_fields": ["url", "ip_address"],
    "hash_findings_for_dedup": true
  }
}

